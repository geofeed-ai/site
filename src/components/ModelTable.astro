---
interface Props {
  rows: [string, string, string, string][];
}

const { rows } = Astro.props;
---

<div class="rounded-lg border border-neutral-800 overflow-hidden">
  <table class="w-full text-xs font-mono">
    <thead>
      <tr class="border-b border-neutral-800 bg-neutral-900">
        <th class="text-left px-4 py-2.5 text-neutral-500 font-normal">field</th>
        <th class="text-left px-4 py-2.5 text-neutral-500 font-normal">type</th>
        <th class="text-left px-4 py-2.5 text-neutral-500 font-normal">constraint</th>
        <th class="text-left px-4 py-2.5 text-neutral-500 font-normal">description</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-neutral-800/60">
      {rows.map(([field, type, constraint, description]) => (
        <tr class="hover:bg-neutral-900/40 transition-colors">
          <td class="px-4 py-2.5 text-emerald-400">{field}</td>
          <td class="px-4 py-2.5 text-neutral-400">{type}</td>
          <td class="px-4 py-2.5 text-neutral-600">{constraint}</td>
          <td class="px-4 py-2.5 text-neutral-500">{description}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
